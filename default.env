# Gemini API Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Global Shortcut Configuration (Linux evdev Key Names)
# - HOLD_KEY: Hold down this key to record, release it to stop and transcribe.
# - TOGGLE_KEYS: Comma-separated list of keys that toggle recording start and stop.
# Common names: KEY_LEFTALT, KEY_RIGHTALT, KEY_CAPSLOCK, KEY_RIGHTCTRL, KEY_RIGHTCTRL, KEY_F10
# - STRICT_MODIFIERS: If true, left and right modifier keys (Alt, Ctrl, Shift) are distinguished and not treated as interchangeable.
HOLD_KEY=KEY_RIGHTALT
TOGGLE_KEYS=KEY_RIGHTCTRL+KEY_RIGHTALT,KEY_RIGHTCTRL+KEY_RIGHTALT
STRICT_MODIFIERS=true

# Translation Shortcut Configuration (Output translated to English)
# - TRANSLATE_HOLD_KEY: Hold down this key combo to record, then output translated English.
# - TRANSLATE_TOGGLE_KEYS: Toggle combo to record and output translated English.
TRANSLATE_HOLD_KEY=KEY_LEFTSHIFT+KEY_RIGHTALT
TRANSLATE_TOGGLE_KEYS=KEY_LEFTSHIFT+KEY_RIGHTCTRL+KEY_RIGHTALT

# Keyboard & Language Configuration
# - KEYBOARD_LAYOUT: Keyboard layout of the system (us, fr/azerty, de/qwertz).
# - LANGUAGE: Primary spoken language for transcription (e.g. French, English, German).
KEYBOARD_LAYOUT=fr
LANGUAGE=French